<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fc.v2.mapper.auto.CustomerTagMapper">

    <resultMap type="com.fc.v2.model.auto.CustomerTag" id="CustomerTagResult">
        <result property="id"    column="id"    />
        <result property="profileId"    column="profile_id"    />
        <result property="tagName"    column="tag_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <select id="selectTagsByProfileId" resultMap="CustomerTagResult" parameterType="Long">
        select id, profile_id, tag_name, create_by, create_time
        from t_customer_tag
        where profile_id = #{profileId}
        order by create_time desc
    </select>

    <delete id="deleteTagById" parameterType="Long">
        delete from t_customer_tag where id = #{id}
    </delete>

    <delete id="deleteTagsByProfileId" parameterType="Long">
        delete from t_customer_tag where profile_id = #{profileId}
    </delete>

    <select id="selectTagByProfileIdAndName" resultMap="CustomerTagResult">
        select id, profile_id, tag_name, create_by, create_time
        from t_customer_tag
        where profile_id = #{profileId} and tag_name = #{tagName}
    </select>

</mapper>
