<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fc.v2.mapper.auto.ServiceFlowPhotoMapper">

    <resultMap type="com.fc.v2.model.auto.ServiceFlowPhoto" id="ServiceFlowPhotoResult">
        <result property="id"    column="id"    />
        <result property="flowId"    column="flow_id"    />
        <result property="photoUrl"    column="photo_url"    />
        <result property="photoName"    column="photo_name"    />
        <result property="sort"    column="sort"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectServiceFlowPhotoVo">
        select id, flow_id, photo_url, photo_name, sort, create_by, create_time
        from t_service_flow_photo
    </sql>

    <select id="selectServiceFlowPhotoById" resultMap="ServiceFlowPhotoResult" parameterType="Long">
        <include refid="selectServiceFlowPhotoVo"/>
        <where>
            id = #{id}
        </where>
    </select>

    <select id="selectServiceFlowPhotoByFlowId" resultMap="ServiceFlowPhotoResult" parameterType="Long">
        <include refid="selectServiceFlowPhotoVo"/>
        <where>
            flow_id = #{flowId}
        </where>
        order by sort asc, id desc
    </select>

    <delete id="deleteServiceFlowPhotoByFlowId" parameterType="Long">
        delete from t_service_flow_photo where flow_id = #{flowId}
    </delete>

</mapper>
