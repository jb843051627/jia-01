<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fc.v2.mapper.auto.ServiceTypeMapper">

    <resultMap type="com.fc.v2.model.auto.ServiceType" id="ServiceTypeResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="price"    column="price"    />
        <result property="duration"    column="duration"    />
        <result property="stock"    column="stock"    />
        <result property="description"    column="description"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectServiceTypeVo">
        select id, name, price, duration, stock, description, status, create_by, create_time, update_by, update_time 
        from t_service_type
    </sql>

    <select id="selectServiceTypeById" resultMap="ServiceTypeResult" parameterType="Long">
        <include refid="selectServiceTypeVo"/>
        <where>  
            id = #{id}
        </where>
    </select>

    <select id="selectServiceTypeList" resultMap="ServiceTypeResult" parameterType="com.fc.v2.model.auto.ServiceType">
        <include refid="selectServiceTypeVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by id asc
    </select>

    <select id="selectEnabledServiceTypeList" resultMap="ServiceTypeResult">
        <include refid="selectServiceTypeVo"/>
        <where>  
            status = '0'
        </where>
        order by id asc
    </select>

    <update id="decreaseStock">
        update t_service_type
        set stock = stock - #{quantity}
        where id = #{id} and stock >= #{quantity}
    </update>

    <update id="increaseStock">
        update t_service_type
        set stock = stock + #{quantity}
        where id = #{id}
    </update>

    <select id="countOrdersByServiceType" resultType="com.fc.v2.model.custom.ServiceTypeStatsVO">
        select
            st.name as name,
            sum(oi.quantity) as count
        from t_order_item oi
        left join t_service_type st on oi.service_type_id = st.id
        left join t_order o on oi.order_id = o.id
        where o.status != '4'
        group by st.id, st.name
        order by count desc
    </select>

</mapper>
